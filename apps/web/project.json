{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/web/src",
  "root": "apps/web",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ng serve",
        "cwd": "apps/web"
      },
      "defaultConfiguration": "development",
      "configurations": {
        "development": {
          "command": "ng serve --configuration=development"
        },
        "production": {
          "command": "ng serve --configuration=production"
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/web/dist"],
      "options": {
        "command": "ng build",
        "cwd": "apps/web"
      },
      "defaultConfiguration": "production",
      "configurations": {
        "development": {
          "command": "ng build --configuration=development"
        },
        "production": {
          "command": "ng build --configuration=production"
        }
      }
    }
  }
}
